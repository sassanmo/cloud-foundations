# Example terraform.tfvars file
# Copy this to terraform.tfvars and update with your values

account_id  = "469240347599"
region      = "eu-west-1"
environment = "prod"
partition   = "aws"  # or "aws-cn" for China, "aws-us-gov" for GovCloud

# KMS Configuration
kms_deletion_window_in_days = 30

# Lifecycle Configuration
noncurrent_version_expiration_days = 90

# S3 Access Logging (optional)
enable_logging = false
# logging_bucket = "my-logging-bucket"  # Specify a separate bucket for logs

# IAM Access Control
create_iam_policies = true

# Specify IAM roles that need access to Terraform state
# Admin roles: Full read/write access (e.g., CI/CD pipelines)
terraform_admin_role_arns = [
  "arn:aws:iam::469240347599:role/TerraformCICD",
  # "arn:aws:iam::469240347599:role/AdminRole"
]

# Read-only roles: Read-only access (e.g., developer roles)
terraform_read_only_role_arns = [
  "arn:aws:iam::469240347599:role/Developers",
  # "arn:aws:iam::469240347599:role/ReadOnlyRole"
]

# CloudTrail Configuration
enable_cloudtrail = true
# cloudtrail_bucket_name = ""  # Leave empty to auto-generate

# S3 Replication for Disaster Recovery
enable_replication  = false
replication_region  = "us-west-2"  # Must be different from primary region

tags = {
  Project     = "cloud-foundations"
  ManagedBy   = "Terraform"
  CostCenter  = "infrastructure"
  Compliance  = "required"
}

